        { name: "recipient", type: "string", required: false, description: "Recipient" }
      ],
      call: ->(a) { P.mail(a["op"], recipient: a["recipient"]) } },
    { name: "rent", description: "Rent a room to save your character and items.",
      params: [], call: ->(_a) { P.rent } },
    { name: "house_admin", description: "Administer a house, optionally naming a player to grant/revoke access.",
      params: [{ name: "player", type: "string", required: false, description: "Player name" }],
      call: ->(a) { P.house_admin(a["player"]) } }
  ].freeze

  TOOLS_BY_NAME = TOOLS.each_with_object({}) { |t, h| h[t[:name]] = t }.freeze

  # ---- MUD session (lazy) --------------------------------------------------

  def self.session
    @session ||= begin
      s = MudManager::Session.new(
        host: ENV["MUD_HOST"] || MudManager::Session::DEFAULT_HOST,
        port: Integer(ENV["MUD_PORT"] || MudManager::Session::DEFAULT_PORT)
      )
      s.open
      s.login(ENV.fetch("MUD_NAME"), ENV.fetch("MUD_PASSWORD"))
      s
    end
  end

  # ---- MCP protocol ---------------------------------------------------------

  def self.input_schema(params)
    props = params.each_with_object({}) do |p, out|
      schema = { "type" => p[:type] }
      schema["enum"] = p[:enum] if p[:enum]
      schema["description"] = p[:description] if p[:description]
      out[p[:name]] = schema
    end
    required = params.select { |p| p[:required] }.map { |p| p[:name] }
    { "type" => "object", "properties" => props, "required" => required }
  end

  def self.tool_list_payload
    TOOLS.map do |t|
      { "name" => t[:name], "description" => t[:description], "inputSchema" => input_schema(t[:params]) }
    end
  end

  def self.coerce_args(tool, raw_args)
    raw_args = raw_args || {}
    out = {}
    tool[:params].each do |p|
      value = raw_args.key?(p[:name]) ? raw_args[p[:name]] : nil
      value = nil if value.is_a?(String) && value.strip.empty? && !p[:required]
      if value.nil? && p.key?(:default)
        value = p[:default]
      end
      value = Integer(value) if p[:type] == "integer" && !value.nil?
      out[p[:name]] = value unless value.nil?
    end
    out
  end

  def self.call_tool(name, raw_args)
    tool = TOOLS_BY_NAME[name]
    return { is_error: true, text: "unknown_tool: no tool named #{name.inspect}" } unless tool

    args = coerce_args(tool, raw_args)
    command = tool[:call].call(args)
    session.send_command(command)
    text = session.read_until_prompt
    { is_error: false, text: text }
  rescue ArgumentError => e
    { is_error: true, text: "argument_error: #{e.message}" }
  rescue MudManager::Session::Error => e
    { is_error: true, text: "session_error: #{e.class}: #{e.message}" }
  end

  def self.handle(msg)
    method = msg["method"]
    id = msg["id"]

    case method
    when "initialize"
      respond(id, "result" => {
        "protocolVersion" => msg.dig("params", "protocolVersion") || "2025-06-18",
        "capabilities" => { "tools" => {} },
        "serverInfo" => { "name" => SERVER_NAME, "version" => SERVER_VERSION }
      })
    when "notifications/initialized"
      # no response expected for a notification
    when "tools/list"
      respond(id, "result" => { "tools" => tool_list_payload })
    when "tools/call"
      name = msg.dig("params", "name")
      arguments = msg.dig("params", "arguments") || {}
      result = call_tool(name, arguments)
      respond(id, "result" => {
        "content" => [{ "type" => "text", "text" => result[:text] }],
        "isError" => result[:is_error]
      })
    else
      respond(id, "error" => { "code" => -32601, "message" => "Method not found: #{method}" }) if id
    end
  end

  def self.respond(id, payload)
    return if id.nil?

    $stdout.puts(JSON.generate({ "jsonrpc" => "2.0", "id" => id }.merge(payload)))
    $stdout.flush
  end

  def self.run
    $stdin.each_line do |line|
      line = line.strip
      next if line.empty?

      begin
        msg = JSON.parse(line)
      rescue JSON::ParserError
        next
      end
      handle(msg)
    end
  end
end

MudManagerMcp.run if $PROGRAM_NAME == __FILE__
