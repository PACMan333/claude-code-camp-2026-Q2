#!/usr/bin/env ruby
# frozen_string_literal: true
#
# mud-manager --mcp
#
# A minimal MCP-over-stdio server exposing MudManager::Primitives as tools,
# backed by a single MudManager::Session opened lazily on the first tool
# call (so `tools/list` still works before any MUD connection is attempted).
# Credentials travel by environment, per the stdio MCP transport convention:
#
#   MUD_HOST      default "localhost"
#   MUD_PORT      default 4000
#   MUD_NAME      required to log in
#   MUD_PASSWORD  required to log in
#
# Speaks JSON-RPC 2.0, one message per line, on stdin/stdout. Only the
# methods Boukensha::Mcp::Client actually sends are implemented: initialize,
# notifications/initialized, tools/list, tools/call.

require "json"

$LOAD_PATH.unshift File.expand_path("../lib", __dir__)
require "mud_manager"

module MudManagerMcp
  SERVER_NAME = "mud-manager"
  SERVER_VERSION = "0.1.0"

  P = MudManager::Primitives

  # Each entry: name, description, an ordered list of param specs, and a
  # build lambda that turns a string-keyed args hash into a
  # MudManager::Primitives::Command. Param spec keys: :name, :type
  # ("string"/"integer"), :required, :enum (optional), :description,
  # :default (optional, used when the argument is omitted).
  TOOLS = [
    # ---------- Perception (look first: the most fundamental action) ----------
    { name: "look", description: "Look around the room you are currently in, or examine a specific " \
                                  "object/character/direction. To see the room itself (its name, " \
                                  "description, exits, and contents) call this with NO arguments at " \
                                  "all — do not pass target: \"room\" or similar, there is no object " \
                                  "literally named \"room\" to look at. Only set target (and " \
                                  "optionally preposition) when looking at something specific, e.g. " \
                                  "target: \"sword\" or preposition: \"north\" with no target to peek " \
                                  "in a direction.",
      params: [
        { name: "mode", type: "string", required: false, enum: P::LOOK_MODES, default: "look", description: "look or read" },
        { name: "target", type: "string", required: false,
          description: "A specific object, character, or exit to look at — omit this entirely to " \
                        "just see the room you're in (never pass \"room\"/\"here\"/\"surroundings\")" },
        { name: "preposition", type: "string", required: false, enum: P::LOOK_PREPS, description: "in/at/direction" }
      ],
      call: ->(a) {
        target = a["target"]
        # A model occasionally asks to "look at room"/"look at here" when it
        # actually just wants the room description — there's no such object
        # on a real MUD, so treat these as the no-argument, whole-room look.
        target = nil if target && %w[room here surroundings around myself].include?(target.strip.downcase)
        preposition = target.nil? ? nil : a["preposition"]
        P.look(mode: a.fetch("mode", "look"), target: target, preposition: preposition)
      } },

